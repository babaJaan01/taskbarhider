#include <winres.h>
#include "resource.h"

#ifndef TASKBARHIDER_VERSION
#define TASKBARHIDER_VERSION        3,0,1,0
#define TASKBARHIDER_VERSION_STR    "3.0.1.0"
#endif

// Use the system's own shell tray icon so we don't need to ship a .ico file.
// Replace with `IDI_APP_ICON ICON "app.ico"` + a real .ico if you want a custom icon.

VS_VERSION_INFO VERSIONINFO
 FILEVERSION     TASKBARHIDER_VERSION
 PRODUCTVERSION  TASKBARHIDER_VERSION
 FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS       VS_FF_DEBUG
#else
 FILEFLAGS       0
#endif
 FILEOS          VOS_NT_WINDOWS32
 FILETYPE        VFT_APP
 FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "babaJaan01"
            VALUE "FileDescription",  "TaskbarHider - auto-hide the Windows taskbar when the desktop is empty"
            VALUE "FileVersion",      TASKBARHIDER_VERSION_STR
            VALUE "InternalName",     "TaskbarHider"
            VALUE "LegalCopyright",   "MIT License"
            VALUE "OriginalFilename", "TaskbarHider.exe"
            VALUE "ProductName",      "TaskbarHider"
            VALUE "ProductVersion",   TASKBARHIDER_VERSION_STR
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

// NOTE: The application manifest is fed to the linker via /MANIFESTINPUT:
// (see CMakeLists.txt). Declaring it here as well would create a duplicate
// MANIFEST resource and fail with CVT1100.
